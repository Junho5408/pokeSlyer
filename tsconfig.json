{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "paths": {
      "@game/*": ["./src/game/*"],
      "@scenes/*": ["./src/scenes/*"],
      "@data/*": ["./src/data/*"],
      "@ui/*": ["./src/ui/*"],
      "@t/*": ["./src/types/*"]
    }
  },
  "include": ["src"]
}
